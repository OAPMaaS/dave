OLLAMA_MODEL=llama3.2
MAX_SUPERVISOR_ROUNDS=3

# ── LLM provider (Anthropic default) ─────────────────────────────────────────
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
GROQ_API_KEY=
ROLE_PROVIDER_CRITIC=groq

# ── Langfuse observability (optional) ────────────────────────────────────────
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=https://cloud.langfuse.com

# ── Analytics / PostgreSQL ────────────────────────────────────────────────────
# Set DB_ENABLED=true only when a PostgreSQL instance is reachable.
# When false (default), the Analytics tab shows a "not connected" message
# and makes zero network calls — safe for laptop / demo use.
DB_ENABLED=false
DB_HOST=localhost
DB_PORT=5432
DB_NAME=dave
DB_USER=dave
DB_PASSWORD=dave        # change this to your real password in production
