OLLAMA_MODEL=llama3.2
MAX_SUPERVISOR_ROUNDS=3

# ── Permissions ───────────────────────────────────────────────────────────────
# Roles: viewer (chat only) | analyst (chat + audit/upload) | admin (all, default)
ACTIVE_ROLE=admin
# JSON dict mapping api_key → role for multi-user / API access
# PERMISSION_KEYS={"sk-abc123":"analyst","sk-xyz789":"admin"}
PERMISSION_KEYS={}

# ── Application identity ──────────────────────────────────────────────────────
APP_NAME=AI Auditor          # displayed in UI, bot messages, and executor prompts
BRAND_NAME=                  # canonical brand name to enforce (empty = disabled)
DEFAULT_OWNER=               # fallback owner when doc author cannot be resolved
OWNER_USERNAMES=             # comma-separated owner usernames, e.g. alice,bob

# ── LLM provider (Anthropic default) ─────────────────────────────────────────
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
GROQ_API_KEY=
ROLE_PROVIDER_CRITIC=groq

# ── Langfuse observability (optional) ────────────────────────────────────────
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=https://cloud.langfuse.com

# ── Analytics / PostgreSQL ────────────────────────────────────────────────────
# Set DB_ENABLED=true only when a PostgreSQL instance is reachable.
# When false (default), the Analytics tab shows a "not connected" message
# and makes zero network calls — safe for laptop / demo use.
DB_ENABLED=false
DB_HOST=localhost
DB_PORT=5432
DB_NAME=audit
DB_USER=audit
DB_PASSWORD=             # set your real password in production

# ── MCP remote servers (optional) ────────────────────────────────────────────
# JSON list of remote HTTP MCP servers. Supported transports: sse | streamable_http
# MCP_HTTP_SERVERS=[{"name":"my-server","transport":"streamable_http","url":"https://example.com/mcp","headers":{"Authorization":"Bearer sk-..."}}]
MCP_HTTP_SERVERS=[]

# ── Telegram notifications (optional) ────────────────────────────────────────
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_OWNERS=alice,bob         # comma-separated usernames
# TELEGRAM_ALICE_CHAT_ID=123456789  # one entry per owner listed above
# TELEGRAM_BOB_CHAT_ID=987654321
# TELEGRAM_DEFAULT_CHAT_ID=         # admin fallback when owner has no chat_id
